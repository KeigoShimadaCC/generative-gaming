  "narration": {
    "floorIntro": "The ring of rooms waits with its doors open, as if it has learned how little you ask of stone.",
    "observations": [
      {
        "id": "kept-hand-observation",
        "triggerTag": "kept-hand",
        "text": "You carry what you find and spend none of it; the Deep sets small gifts where even caution can reach."
      },
      {
        "id": "closed-ways-observation",
        "triggerTag": "closed-ways",
        "text": "Beyond the near room, two Made things count the doors you leave unopened."
      },
      {
        "id": "signature-counter-observation",
        "triggerTag": "signature-counter",
        "text": "The Counter of Closed Ways lifts its head. It does not bar the path; it asks whether you will pass another story by."
      }
    ]
  },
