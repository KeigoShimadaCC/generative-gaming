  "narration": {
    "floorIntro": "The Deep makes a wide room with no teeth near the door. It has counted your careful steps.",
    "observations": [
      {
        "id": "two-cells-seen",
        "triggerTag": "two-cells-seen",
        "text": "You see little, and the Deep answers with open stone instead of a snare."
      },
      {
        "id": "no-blood-taken",
        "triggerTag": "no-blood-taken",
        "text": "The Listener at Two Steps waits far off, made for the mercy you keep choosing."
      },
      {
