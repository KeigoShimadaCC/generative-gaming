  "narration": {
    "floorIntro": "The Deep has counted what you carried past hunger, past speech, past the small bodies you chose to kill.",
    "observations": [
      {
        "id": "hoard-observed",
        "triggerTag": "coin-hoard",
        "text": "Gold waits in a clean heap. It does not hide from you. It only asks what else you meant to keep."
      },
      {
        "id": "avoidance-observed",
        "triggerTag": "paths-not-taken",
        "text": "Two halls bend away without shame. You have spared many doors your blood, and I remember."
      },
      {
        "id": "near-end-observed",
        "triggerTag": "close-call",
        "text": "Here is a narrow place like the one that almost took you. This time the warning is plain."
      }
    ]
