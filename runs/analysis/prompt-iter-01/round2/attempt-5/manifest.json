  "narration": {
    "floorIntro": "The Deep has kept count. It opens a last quiet hall and lets your pockets answer first.",
    "observations": [
      {
        "id": "hoard-callback",
        "triggerTag": "hoard-counted",
        "text": "You have carried much and spent little. The stone does not blame you. It only remembers the weight."
      },
      {
        "id": "moss-silt-callback",
        "triggerTag": "old-kills-return",
        "text": "Moss darkens one wall; silt pales another. The small dead have arrived before you."
      },
