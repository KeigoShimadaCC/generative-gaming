  "narration": {
    "floorIntro": "The ring of rooms waits with its hands open, and each hand knows what you have kept.",
    "observations": [
      {
        "id": "hoard-count",
        "triggerTag": "coin-seen",
        "text": "The copper lies apart from danger, bright enough to ask why you carry so much and spend so little."
      },
      {
        "id": "narrow-mercy",
        "triggerTag": "enemy-avoided",
        "text": "You pass a made thing by, and the Deep lets the silence remember your shape."
      },
      {
        "id": "low-sight",
        "triggerTag": "new-room",
        "text": "You have seen little and survived much; the dark now shows you one honest edge at a time."
      }
