      {
        "id": "hoard-seen",
        "triggerTag": "old-stock-hoard",
        "text": "You pass another useful thing, or take it. The Deep remembers both weights in your pack."
      },
      {
        "id": "quiet-path-seen",
        "triggerTag": "fights-avoided",
        "text": "The Made stand where a cautious foot might turn aside. Their patience is almost polite."
      },
      {
        "id": "narrow-sight-seen",
        "triggerTag": "few-cells-seen",
        "text": "Most doors keep their dark. You have taught the Deep to make the seen rooms matter."
      }
