  "narration": {
    "floorIntro": "The ring of rooms waits with its hands open, remembering how often you chose speech over steel.",
    "observations": [
      {
        "id": "obs-low-combat",
        "triggerTag": "first-made-seen",
        "text": "It does not rush you. It has learned that you look for a mouth before a wound."
      },
      {
        "id": "obs-hoard",
        "triggerTag": "coin-found",
        "text": "The coins lie apart from the useful things, bright enough to ask whether you still gather more than you spend."
      },
      {
        "id": "obs-small-map",
        "triggerTag": "outer-ring-entered",
        "text": "Most doors remain untried behind you. The Deep marks each untouched latch without blame."
      }
    ]
