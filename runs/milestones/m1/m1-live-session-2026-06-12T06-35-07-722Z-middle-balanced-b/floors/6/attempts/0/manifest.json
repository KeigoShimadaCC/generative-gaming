  "narration": {
    "floorIntro": "The Deep has counted your soft steps and saved a ring of rooms for them.",
    "observations": [
      {
        "id": "obs-few-fights",
        "triggerTag": "avoided-fights",
        "text": "You have left many teeth unused behind you; the stone notices mercy and caution wearing one cloak."
      },
      {
        "id": "obs-many-talks",
        "triggerTag": "many-talks",
        "text": "So many words have gone out of you, and none have been sworn into burden."
      },
      {
        "id": "obs-small-map",
        "triggerTag": "small-map-seen",
        "text": "The dark keeps most of itself folded, because you have asked so little of the floor."
      }
    ]
