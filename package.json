{
  "name": "generative-gaming",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24.0.0 <26.0.0"
  },
  "scripts": {
    "typecheck": "node --input-type=module -e \"import{rmSync}from'node:fs';try{rmSync('.next',{recursive:true,force:true})}catch{}\" && tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.next.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run lint && pnpm test",
    "verify:ci": "node scripts/verify-ci.mjs",
    "e2e": "XDG_CACHE_HOME=${XDG_CACHE_HOME:-.cache} PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-.cache/ms-playwright} playwright test",
    "e2e:fullclear": "FULLCLEAR=1 XDG_CACHE_HOME=${XDG_CACHE_HOME:-.cache} PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-.cache/ms-playwright} playwright test --project=fullclear",
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev -p ${PORT:-3001}",
    "build": "next build",
    "evals": "pnpm dlx tsx src/evals/runner/run.ts",
    "play": "npx --yes tsx src/cli/play.ts",
    "simulate": "npx --yes tsx src/cli/simulate.ts",
    "replay": "npx --yes tsx src/cli/replay.ts",
    "generate-art": "pnpm dlx tsx scripts/generate-art.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "next": "15.5.19",
    "pixi.js": "^8.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "autoprefixer": "10.4.21",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.3",
    "prettier": "3.8.4",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
